# =============================================================================
# Cold Email Campaign Manager — Environment Variables
# =============================================================================
# HOW TO USE:
#   cp .env.example .env
#   Then fill in your real values in .env
#
# RULES:
#   ✅ .env.example  → committed (safe template, no real secrets)
#   ❌ .env          → gitignored (real secrets, NEVER commit)
#
# NEXT_PUBLIC_ PREFIX RULE:
#   Variables with NEXT_PUBLIC_ are bundled into client-side JS and
#   visible to anyone with browser DevTools. Only expose what is safe.
#   Everything else is server-only and never reaches the browser.
# =============================================================================


# ── Supabase ──────────────────────────────────────────────────────────────────
# Where to find: Supabase Dashboard → your project → Settings → API
#
# KEY FORMAT NOTE: Supabase rolled out new key formats in 2025.
#   New format (preferred): sb_publishable_... and sb_secret_...
#   Legacy format (still works, deprecated end-2026): eyJ... JWT keys
#   Use whichever your dashboard shows — supabase-js supports both.
#
# Your project's REST endpoint. Safe to expose — it's just an address.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
#
# Publishable key (new) OR anon key (legacy). Safe to expose — RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key-here
#
# Secret key (new) OR service_role key (legacy). SERVER ONLY. Bypasses RLS.
# Used only by the cron job (server-side). NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-secret-key-here


# ── Email — Resend ────────────────────────────────────────────────────────────
# Where to find: https://resend.com/api-keys
# Grants ability to send email on your behalf. Keep server-only.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── AI — Anthropic Claude ─────────────────────────────────────────────────────
# Where to find: https://console.anthropic.com/settings/keys
# Grants ability to call Claude API and consume your credits. Keep server-only.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Cron Security ─────────────────────────────────────────────────────────────
# A secret YOU generate (see README for command: openssl rand -hex 32).
# Vercel Cron sends this as: Authorization: Bearer <CRON_SECRET>
# Your /api/cron route checks this header and rejects any call without it.
# This prevents anyone on the internet from triggering your cron endpoint.
# Also set this value in: Vercel Dashboard → Project → Settings → Env Vars
CRON_SECRET=your-random-hex-secret-at-least-32-chars


# ── Resend sender + unsubscribe ───────────────────────────────────────────────
# The "From" address for all outgoing emails. Must be a verified Resend domain.
RESEND_FROM_EMAIL="Your Name <you@yourdomain.com>"
#
# Where unsubscribe replies go. Set to a real inbox until your sending domain
# has inbound MX enabled. Once inbound is configured, remove this var —
# the cron route falls back to extractEmail(RESEND_FROM_EMAIL).
# TODO T6.7: remove after enabling MX receiving on sending domain.
RESEND_UNSUBSCRIBE_EMAIL=you@gmail.com


# ── Supabase CLI ──────────────────────────────────────────────────────────────
# Personal access token for the Supabase CLI (supabase db push, etc.)
# Where to find: https://supabase.com/dashboard/account/tokens → Generate new token
# LOCAL MACHINE ONLY — do NOT add to Vercel env vars.
SUPABASE_ACCESS_TOKEN=sbp_your-access-token-here
