# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/

# ── Environment / Secrets ─────────────────────────────────────────────────────
# NEVER commit real secrets. .env.example (safe template) is committed instead.
.env
.env.local
.env.*.local

# ── Vercel CLI local config ───────────────────────────────────────────────────
.vercel/

# ── OS / Editor artifacts ─────────────────────────────────────────────────────
.DS_Store
.idea/
*.iml
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript incremental build cache ────────────────────────────────────────
*.tsbuildinfo

# ── Distribution / build artifacts ───────────────────────────────────────────
dist/
build/

# ── Test coverage output ──────────────────────────────────────────────────────
coverage/
